        const form = document.getElementById('approvalForm');
        const actionInput = document.getElementById('action-input');
        const fileInput = document.getElementById('signature-file');

        function handleSubmission(e, action) {
            e.preventDefault(); // Stop the form from submitting immediately

            // 1. Validate that a file is selected
            if (!fileInput.files || fileInput.files.length === 0) {
                alert('Please upload your signature attachment before submitting.');
                return;
            }

            // 2. Set the action value ('approve' or 'reject')
