     <%- include('partials/nav') %>

    <div class="summary-box">
        <p><strong>Requisition ID:</strong> OCT #<%= requisition.id %></p>
        <p><strong>Staff:</strong> <%= requisition.staffName || 'Unknown' %></p>
        <p><strong>Department:</strong> <%= requisition.department || 'N/A' %></p>
        <p><strong>Date:</strong> <%= requisition.requestDate ? new Date(requisition.requestDate).toLocaleDateString() : 'N/A' %></p>
        <p><strong>Grand Total:</strong> KES 
            <% 
                // SAFE GRAND TOTAL CALCULATION
                let totalAmount = 0;
                
                // Try to get from grandTotal first
                if (requisition.grandTotal && !isNaN(parseFloat(requisition.grandTotal))) {
                    totalAmount = parseFloat(requisition.grandTotal);
                } 
                // Otherwise try to calculate from items
                else if (requisition.items) {
                    try {
                        let itemsArray = requisition.items;
                        if (typeof requisition.items === 'string') {
                            itemsArray = JSON.parse(requisition.items);
                        }
                        if (Array.isArray(itemsArray)) {
                            totalAmount = itemsArray.reduce((sum, item) => {
                                return sum + (parseFloat(item.total) || parseFloat(item.qty) * parseFloat(item.unitPrice) || 0);
                            }, 0);
                        }
                    } catch(e) {
                        console.error('Error calculating total:', e);
                        totalAmount = 0;
                    }
                }
                
                // Ensure it's a valid number
                totalAmount = isNaN(totalAmount) ? 0 : totalAmount;
            %>
            <%= totalAmount.toFixed(2) %>
        </p>  
        <p>
          
                <a href="/<%= user.role %>/dashboard" class="btn-back" style="color: #fff; background: #0071bc; padding: 7px 12px; text-decoration: none; border-radius: 4px; display: inline-block;">Back to Dashboard</a>
        </p>
    </div>

    <table>
        <thead>
            <tr style="font-weight: bold; background: #f5f5f5;">
                <th>Item Description</th>
                <th>Quantity</th>
                <th>Unit Price (KES)</th>
                <th>Total (KES)</th>
             </tr>
        </thead>
        <tbody>
            <% 
            let itemsArray = [];
            if (requisition.items) {
                if (Array.isArray(requisition.items)) {
                    itemsArray = requisition.items;
                } else if (typeof requisition.items === 'string') {
                    try {
                        itemsArray = JSON.parse(requisition.items);
                    } catch(e) {
                        console.error('Error parsing items:', e);
                        itemsArray = [];
                    }
                }
            }
            
            if (itemsArray.length > 0) {
                itemsArray.forEach(item => { 
                    const itemTotal = Number(item.total) || (Number(item.qty) * Number(item.unitPrice)) || 0;
            %>
            <tr>
                <td><%= item.description || 'N/A' %></td>
                <td><%= item.qty || 0 %></td>
                <td>KES <%= (Number(item.unitPrice) || 0).toFixed(2) %></td>
               <td style="padding: 12px;" class="<%= requisition.grandTotal > 100000 ? 'high-value' : '' %>">
                    KES <%= Number(requisition.grandTotal).toLocaleString(undefined, {minimumFractionDigits: 2}) %>
                </td>
            </tr>
            <% }); } else { %>
            <tr>
                <td colspan="4" style="text-align: center;">No items found</td>
            </tr>
            <% } %>
        </tbody>
    </table>


