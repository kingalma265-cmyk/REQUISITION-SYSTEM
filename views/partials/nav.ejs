


<nav class="main-nav">
    <a href="/home" class="<%= (locals.currentPage === 'new') ? 'active' : '' %>">Home</a>
    <% if (locals.user && locals.user.role === 'hod') { %>
        <a href="/hod/dashboard" class="<%= (locals.currentPage === 'hod') ? 'active' : '' %>">HOD Dashboard</a>
    <% } %>
    <% if (locals.user && locals.user.role === 'finance') { %>
        <a href="/finance/dashboard" class="<%= (locals.currentPage === 'finance') ? 'active' : '' %>">Finance</a>
    <% } %>
    <% if (locals.user && locals.user.role === 'director') { %>
        <a href="/director/dashboard" class="<%= (locals.currentPage === 'director') ? 'active' : '' %>">Director</a>
    <% } %>
    <a href="/logout" class="logout-link" style="color:red;">Logout</a>
</nav>
<style>
.p{
    color:#c6cfdd;
}
.main-nav {
    background: #1e3a8a;
    padding: 0.6rem 1rem;
    text-align: center;
    border-radius: 8px;
    margin: 1rem auto;
    max-width: 980px;
}

.main-nav a {
    color: #fff;
    text-decoration: none;
    margin: 0 0.8rem;
    font-weight: 600;
}

.main-nav a:hover {
    text-decoration: underline;
}

@media (max-width: 640px) {
    .main-nav a {
        display: block;
        margin: 0.25rem 0;
    }
}
</style>










