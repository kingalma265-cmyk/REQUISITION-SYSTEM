<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password | Octagon Requisition System</title>
    <link rel="stylesheet" href="/styles/index.css">
    <style>
        body {
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            background-color: #f1f5f9;
            margin: 0;
            font-family: Arial, sans-serif;
        }

        .card {
            background: white;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
            width: 100%;
            max-width: 400px;
            text-align: center;
        }

        #logo {
            max-width: 150px;
            margin-bottom: 20px;
        }

        h2 {
            color: #1e3a8a;
            margin-bottom: 8px;
            font-size: 1.5rem;
        }

        p {
            color: #64748b;
            font-size: 0.9rem;
            margin-bottom: 24px;
        }

        .form-group {
            text-align: left;
            margin-bottom: 16px;
        }

        label {
            display: block;
            font-size: 0.85rem;
            font-weight: 600;
            color: #475569;
            margin-bottom: 6px;
        }

        input {
            width: 100%;
            padding: 12px;
            border: 1px solid #e2e8f0;
            border-radius: 6px;
            font-size: 1rem;
            box-sizing: border-box;
        }

        input:focus {
            outline: none;
            border-color: #1e3a8a;
            ring: 2px solid #bfdbfe;
        }

        .btn {
            width: 100%;
            background-color: #1e3a8a;
            color: white;
            padding: 12px;
            border: none;
            border-radius: 6px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.2s;
            margin-top: 10px;
        }

        .btn:hover {
            background-color: #172554;
        }

        .btn-success {
            background-color: #15803d;
        }

        .error-msg {
            color: #b91c1c;
            background: #fee2e2;
            padding: 10px;
            border-radius: 6px;
            font-size: 0.85rem;
            margin-bottom: 16px;
        }

        .success-msg {
            color: #15803d;
            background: #dcfce7;
            padding: 15px;
            border-radius: 6px;
            font-size: 0.9rem;
            margin-bottom: 16px;
            text-align: left;
            line-height: 1.5;
        }

        .steps {
            text-align: left;
            margin: 16px 0;
            padding: 0;
            list-style: none;
        }

        .steps li {
            padding: 6px 0;
            font-size: 0.85rem;
            color: #475569;
        }

        .steps li::before {
            content: "→ ";
            color: #1e3a8a;
            font-weight: bold;
        }

        .email-display {
            font-size: 0.95rem;
            color: #1e293b;
            margin: 0 0 20px;
            font-weight: 600;
        }

        .otp-input {
            display: none;
        }

        .otp-boxes {
            display: grid;
            grid-template-columns: repeat(6, minmax(48px, 1fr));
            gap: 10px;
            justify-content: center;
            margin: 0 auto;
            max-width: 320px;
        }

        .otp-box {
            width: 100%;
            min-height: 56px;
            border: 2px solid #cbd5e1;
            border-radius: 14px;
            background: #f8fafc;
            font-size: 1.8rem;
            text-align: center;
            color: #0f172a;
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .otp-box:focus {
            border-color: #1e3a8a;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15);
        }

        .resend-link {
            margin-top: 16px;
            font-size: 0.9rem;
            color: #475569;
        }

        .resend-link a {
            color: #1e3a8a;
            text-decoration: none;
            font-weight: 600;
        }

        .resend-link a:hover {
            text-decoration: underline;
        }
    </style>
</head>
<body>
    <div class="card">
        <img src="/Images/octagon-logo.png" id="logo" alt="Octagon Africa">
        <h2>Forgot Password</h2>

        <% if (message) { %>
            <div class="success-msg">
                <strong><%= message %></strong>
            </div>
            <% if (error) { %>
                <div class="error-msg"><%= error %></div>
            <% } %>
            <p style="text-align: left; margin-bottom: 8px; color: #475569; font-size: 0.95rem;">First, enter the code sent to your email address</p>
            <p class="email-display"><%= resetEmail || '' %></p>
            <form action="/verify-otp" method="POST">
                <input type="hidden" name="otp" id="otp">
                <input type="hidden" name="email" value="<%= resetEmail || '' %>">
                <div class="otp-boxes" id="otp-boxes">
                    <input type="tel" inputmode="numeric" pattern="[0-9]*" maxlength="1" class="otp-box" aria-label="OTP digit 1">
                    <input type="tel" inputmode="numeric" pattern="[0-9]*" maxlength="1" class="otp-box" aria-label="OTP digit 2">
                    <input type="tel" inputmode="numeric" pattern="[0-9]*" maxlength="1" class="otp-box" aria-label="OTP digit 3">
                    <input type="tel" inputmode="numeric" pattern="[0-9]*" maxlength="1" class="otp-box" aria-label="OTP digit 4">
                    <input type="tel" inputmode="numeric" pattern="[0-9]*" maxlength="1" class="otp-box" aria-label="OTP digit 5">
                    <input type="tel" inputmode="numeric" pattern="[0-9]*" maxlength="1" class="otp-box" aria-label="OTP digit 6">
                </div>
                <div class="resend-link" id="resend-link-container">
                    Didn&apos;t receive a code? <a href="/forgot-password/resend" id="resend-link">Resend it</a>.
                </div>
                <button type="submit" class="btn" style="margin-top: 20px;">Continue</button>
            </form>
            <script>
                document.addEventListener('DOMContentLoaded', function () {
                    const boxes = Array.from(document.querySelectorAll('.otp-box'));
                    const hiddenOtp = document.getElementById('otp');
                    const resendLink = document.getElementById('resend-link');
                    const resendContainer = document.getElementById('resend-link-container');
                    const resendAllowedAt = <%= typeof resendAllowedAt !== 'undefined' && resendAllowedAt ? resendAllowedAt : 0 %>;

                    const updateHiddenOtp = () => {
                        hiddenOtp.value = boxes.map(input => input.value.trim()).join('');
                    };

                    const setResendTimer = () => {
                        const now = Date.now();
                        const cooldown = resendAllowedAt - now;

                        if (cooldown > 0) {
                            resendLink.style.pointerEvents = 'none';
                            resendLink.style.opacity = '0.5';
                            const secondsLeft = Math.ceil(cooldown / 1000);
                            resendContainer.innerHTML = `Please wait <strong>${secondsLeft}s</strong> before resending.`;

                            const interval = setInterval(() => {
                                const remaining = resendAllowedAt - Date.now();
                                if (remaining <= 0) {
                                    clearInterval(interval);
                                    resendContainer.innerHTML = 'Didn&apos;t receive a code? <a href="/forgot-password/resend" id="resend-link">Resend it</a>.';
                                } else {
                                    resendContainer.innerHTML = `Please wait <strong>${Math.ceil(remaining / 1000)}s</strong> before resending.`;
                                }
                            }, 250);
                        }
                    };

                    boxes.forEach((input, index) => {
                        input.addEventListener('input', (event) => {
                            const value = event.target.value.replace(/\D/g, '');
                            if (!value) {
                                event.target.value = '';
                                updateHiddenOtp();
                                return;
                            }

                            const digits = value.split('');
                            event.target.value = digits[0];

                            if (digits.length > 1) {
                                digits.slice(1).forEach((digit, offset) => {
                                    const nextBox = boxes[index + 1 + offset];
                                    if (nextBox) {
                                        nextBox.value = digit;
                                    }
                                });
                            }

                            const nextIndex = Math.min(boxes.length - 1, index + digits.length);
                            if (nextIndex !== index) {
                                boxes[nextIndex].focus();
                            } else if (index < boxes.length - 1) {
                                boxes[index + 1].focus();
                            }
                            updateHiddenOtp();
                        });

                        input.addEventListener('keydown', (event) => {
                            if (event.key === 'Backspace' && !event.target.value && index > 0) {
                                boxes[index - 1].focus();
                            }
                        });
                    });

                    boxes[0].focus();
                    setResendTimer();
                });
            </script>
        <% } else { %>
            <p>Enter your email to receive an OTP and temporary password.</p>

            <% if (error) { %>
                <div class="error-msg"><%= error %></div>
            <% } %>

            <form action="/forgot-password" method="POST">
                <div class="form-group">
                    <label for="email">Email Address</label>
                    <input type="email" name="email" id="email" required placeholder="e.g. brian.wekesa@octagonafrica.com">
                </div>

                <button type="submit" class="btn">Send OTP</button>
            </form>
        <% } %>

        <p style="text-align: center; margin-top: 20px;">
            <a href="/login" style="color: #1e3a8a; text-decoration: none;">← Back to Login</a>
        </p>
    </div>
</body>
</html>
