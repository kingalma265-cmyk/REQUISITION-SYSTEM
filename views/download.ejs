<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <style>
        /* PDF Page Setup */
        @page {
            size: A4;
            margin: 15mm;
        }
        body {
            font-family: 'Helvetica', 'Arial', sans-serif;
            color: #333;
            line-height: 1.5;
            margin: 0;
            padding: 20px; /* Reduced slightly to prevent page overflow */
        }
        .status-text { font-weight: bold; font-size: 14px; margin-top: 5px; }
        .text-approved { color: #22863a; } /* Green */
        .text-pending { color: #999999; }  /* Gray */

        .watermark {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) rotate(-45deg);
            font-size: 80px;
            color: rgba(200, 0, 0, 0.15); /* Very light red */
            z-index: -1; /* Places it behind the text */
            font-weight: bold;
            text-transform: uppercase;
            white-space: nowrap;
            pointer-events: none;
            width: 100%;
            text-align: center;
        }

        .header-container {
            border-bottom: 3px solid #0056b3;
            padding-bottom: 15px;
            margin-bottom: 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .logo {
            max-width: 180px;
            height: auto;
        }
        .title-section {
            text-align: right;
        }
        .title-section h1 {
            margin: 0;
            color: #0056b3;
            font-size: 22px;
            text-transform: uppercase;
        }

        /* Status Badge */
        .status-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 4px;
            font-weight: bold;
            font-size: 12px;
            margin-top: 8px;
            border: 1px solid;
            text-transform: uppercase;
        }
        .status-APPROVED { background-color: #e6ffed; color: #22863a; border-color: #22863a; }
        .status-PENDING_HOD, .status-PENDING { background-color: #fffdef; color: #735c0f; border-color: #735c0f; }
        .status-REJECTED { background-color: #ffeef0; color: #d73a49; border-color: #d73a49; }

        /* Meta Information Grid */
        .info-table {
            width: 100%;
            margin-bottom: 25px;
            border-collapse: collapse;
        }
        .info-table td {
            padding: 5px 0;
            font-size: 13px;
        }
        .label {
            font-weight: bold;
            color: #555;
            width: 15%;
        }
        .value {
            width: 35%;
        }

        /* Main Items Table */
        .item-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 30px;
            table-layout: fixed;
        }
        .item-table th,
        .item-table td {
            word-break: break-word;
        }
        .item-table th {
            background-color: #f8f9fa;
            border-bottom: 2px solid #dee2e6;
            padding: 10px;
            text-align: left;
            font-size: 12px;
            color: #0056b3;
        }
        .item-table td {
            padding: 10px;
            border-bottom: 1px solid #eee;
            font-size: 12px;
        }
        .item-table th:nth-child(3),
        .item-table td:nth-child(3) {
            width: 14%;
        }
        .item-table th:nth-child(4),
        .item-table td:nth-child(4) {
            width: 24%;
        }
        .item-table th:nth-child(7),
        .item-table td:nth-child(7) {
            width: 12%;
        }
        .item-table tr:nth-child(even) { background-color: #fafafa; }

        /* Totals */
        .totals-area {
            text-align: right;
            margin-top: 10px;
            margin-bottom: 40px;
        }
        .grand-total {
            font-size: 16px;
            font-weight: bold;
            color: #0c5cb1;
            border-top: 2px solid #333;
            display: inline-block;
            padding-top: 10px;
            min-width: 200px;
        }

        /* Cleaned & Balanced Signatures Container Layout */
        .signature-section {
            margin-top: 40px;
            display: flex;
            justify-content: space-between;
            width: 100%;
        }
        .sig-box {
            width: 42%; /* Leaves space on the sides for a clean look */
            text-align: center;
        }
        .sig-line {
            border-top: 2px solid #333; /* Slightly darker and more structural border */
            padding-top: 8px;
            font-weight: bold;
            font-size: 13px;
            text-transform: uppercase;
        }
        .sig-image-container {
            height: 65px;
            display: flex;
            justify-content: center;
            align-items: center;
            margin-bottom: 5px;
        }
        .sig-image { 
            max-height: 60px; 
            max-width: 100%; 
            display: block; 
            margin: 0 auto;
            object-fit: contain;
        }
        .sig-name {
            font-size: 11px;
            color: #666;
            font-style: italic;
            margin-top: 2px;
        }

        /* Footer */
        .footer {
            position: fixed;
            bottom: 0;
            width: 100%;
            text-align: center;
            font-size: 10px;
            color: #999;
            padding: 10px 0;
            border-top: 1px solid #eee;
        }
    </style>
</head>
<body>

    <div class="header-container">
        <img src="data:image/png;base64, <%= logo %>" class="logo" alt="Octagon Logo">
        <div class="title-section">
            <h1>Internal Requisition</h1>
            <div class="status-badge status-<%= r.status %>">
                <%= r.status %>
            </div>
        </div>
    </div>

    <table class="info-table">
        <tr>
            <td class="label">Staff Name:</td>
            <td class="value"><%= r.staffName %></td>
            <td class="label">Req ID:</td>
            <td class="value">OCT #<%= r.id %></td>
        </tr>
        <tr>
            <td class="label">Department:</td>
            <td class="value"><%= r.department %></td>
            <td class="label">Date:</td>
            <td class="value"><%= new Date(r.requestDate || r.createdAt).toLocaleDateString('en-GB') %></td>
        </tr>
    </table>

    <table class="item-table">
        <thead>
            <tr>
                <th>Budget Line</th>
                <th>Cost Centre</th>
                <th>Description</th>
                <th style="text-align: center;">Qty</th>
                <th style="text-align: right;">Unit Price</th>
                <th style="text-align: right;">VAT</th>
                <th style="text-align: right;">Total</th>
            </tr>
        </thead>
        <tbody>
            <% if (itemList.length > 0) { %>
                <% itemList.forEach(item => { %>
                    <tr>
                        <td><%= item.budgetLine || 'N/A' %></td>
                        <td><%= (item.costCentre === 'CC001' ? 'OPSL' : item.costCentre === 'CC002' ? 'OIBL' : item.costCentre === 'CC003' ? 'IPM' : item.costCentre || 'N/A') %></td>
                        <td><%= item.description %></td>
                        <td style="text-align: center;"><%= item.qty %></td>
                        <td style="text-align: right;">KES <%= Number(item.unitPrice || 0).toLocaleString() %></td>
                        <td style="text-align: right;">KES <%= Number(item.vat || 0).toLocaleString() %></td>
                        <td style="text-align: right;">KES <%= Number(item.total || 0).toLocaleString() %></td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="7" style="text-align:center; padding: 20px;">No items found.</td>
                </tr>
            <% } %>
        </tbody>
    </table>

    <div class="totals-area">
        <div class="grand-total">
            Grand Total: KES <%= Number(r.grandTotal || 0).toLocaleString() %>
        </div>
    </div>

    <div class="signature-section">

    <% if (r.role === 'HOD') { %>
        <div class="sig-box">
            <div class="sig-line">Director Approval</div>
            <div class="sig-image-container">
                <% if (directorSignatureImage || r.directorSignature) { %>
                    <img src="<%= directorSignatureImage ? directorSignatureImage : (r.directorSignature.startsWith('data:') ? r.directorSignature : ('/' + r.directorSignature.replace(/^\//, ''))) %>" class="sig-image" alt="Director Signature">
                <% } else { %>
                    <div style="height:60px"></div>
                <% } %>
            </div>
            <div class="status-text <%= r.directorSignature ? 'text-approved' : 'text-pending' %>">
                <%= r.directorSignature ? '✓ APPROVED' : '○ PENDING' %>
            </div>
            <div class="sig-name">
                <%= r.directorSignature ? 'Verified by Director' : 'Awaiting Action' %>
            </div>
        </div>

        <div class="sig-box">
            <div class="sig-line">Finance Approval</div>
            <div class="sig-image-container">
                <% if (financeSignatureImage || r.financeSignature) { %>
                    <img src="<%= financeSignatureImage ? financeSignatureImage : (r.financeSignature.startsWith('data:') ? r.financeSignature : ('/' + r.financeSignature.replace(/^\//, ''))) %>" class="sig-image" alt="Finance Signature">
                <% } else { %>
                    <div style="height:60px"></div>
                <% } %>
            </div>
            <div class="status-text <%= r.financeSignature ? 'text-approved' : 'text-pending' %>">
                <%= r.financeSignature ? '✓ APPROVED' : '○ PENDING' %>
            </div>
            <div class="sig-name">
                <%= r.financeSignature ? 'Verified by Finance' : 'Awaiting Action' %>
            </div>
        </div>

    <% } else { %>
        <div class="sig-box">
            <div class="sig-line">HOD Approval</div>
            <div class="sig-image-container">
                <% if (hodSignatureImage || r.hodSignature) { %>
                    <img src="<%= hodSignatureImage ? hodSignatureImage : (r.hodSignature.startsWith('data:') ? r.hodSignature : ('/' + r.hodSignature.replace(/^\//, ''))) %>" class="sig-image" alt="HOD Signature">
                <% } else { %>
                    <div style="height:60px"></div>
                <% } %>
            </div>
            <div class="status-text <%= r.hodSignature ? 'text-approved' : 'text-pending' %>">
                <%= r.hodSignature ? '✓ APPROVED' : '○ PENDING' %>
            </div>
            <div class="sig-name">
                <%= r.hodSignature ? 'Verified by HOD' : 'Awaiting Action' %>
            </div>
        </div>

        <div class="sig-box">
            <div class="sig-line">Finance Approval</div>
            <div class="sig-image-container">
                <% if (financeSignatureImage || r.financeSignature) { %>
                    <img src="<%= financeSignatureImage ? financeSignatureImage : (r.financeSignature.startsWith('data:') ? r.financeSignature : ('/' + r.financeSignature.replace(/^\//, ''))) %>" class="sig-image" alt="Finance Signature">
                <% } else { %>
                    <div style="height:60px"></div>
                <% } %>
            </div>
            <div class="status-text <%= r.financeSignature ? 'text-approved' : 'text-pending' %>">
                <%= r.financeSignature ? '✓ APPROVED' : '○ PENDING' %>
            </div>
            <div class="sig-name">
                <%= r.financeSignature ? 'Verified by Finance' : 'Awaiting Action' %>
            </div>
        </div>
    <% } %>

    </div>

    <div class="footer">
        Generated on <%= new Date().toLocaleString() %> | Octagon Africa Requisition System | Internal Use Only
    </div>
    
    <% if (r.status !== 'APPROVED') { %>
        <div class="watermark">PENDING APPROVAL</div>
    <% } %>

</body>
</html>